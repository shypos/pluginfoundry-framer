# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- WooCommerce Multi-Tenant SaaS Storefront SaaS Variables ---
# Postgres Connection String
DATABASE_URL="postgres://username:password@localhost:5432/woocommerce_saas"

# Redis Cache URI (Optional, falls back to memory cache)
REDIS_URL="redis://localhost:6379"

# Symmetric Secret Key for Encryption/Decryption of client WooCommerce Keys (32 Characters)
ENCRYPTION_KEY="f7a83d9bc02da5eb0df39f3da92cb83a"

# Public storefront endpoint base path (used for Framer integrations documentation)
API_BASE_URL="https://my-saas-platform.com/v1"

# --- Secure Forms Proxy CAPTCHA Secret Credentials ---
# Cloudflare Turnstile Secret Key (server-side only)
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"
# Google reCAPTCHA v2 Secret Key (server-side only)
RECAPTCHA_SECRET_KEY="6LeIxAcTAAAAAGG-vFI1TnFTxW2mY77Y8aaW17Gs"


